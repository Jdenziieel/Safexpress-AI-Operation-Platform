{
  "steps": [
    {
      "agent": "drive_agent",
      "tool": "search_files",
      "inputs": {
        "search_term": "PRODUCTION MATERIALS REQUISITION LIST"
      },
      "output_variables": {
        "source_sheet_id": "results[0].id"
      },
      "description": "Find the source spreadsheet named 'PRODUCTION MATERIALS REQUISITION LIST' and capture its ID"
    },
    {
      "agent": "sheets_agent",
      "tool": "create_sheet",
      "inputs": {
        "title": "ABCDEFG"
      },
      "output_variables": {
        "sheet_id": "sheet_id"
      },
      "description": "Create a new Google Sheet named 'ABCDEFG'"
    },
    {
      "agent": "sheets_agent",
      "tool": "mirror_tabs",
      "inputs": {
        "source_sheet_id": "{{ source_sheet_id }}",
        "target_sheet_id": "{{ sheet_id }}",
        "create_missing": true,
        "clear_existing": true,
        "copy_data": true
      },
      "output_variables": {},
      "description": "Copy all tabs and data from the source spreadsheet into the new 'ABCDEFG' sheet"
    }
  ]
}