{
  "steps": [
    {
      "agent": "gmail_agent",
      "tool": "create_draft_email",
      "inputs": {
        "to": "jdenziieel@gmail.com",
        "subject": "Pakyu",
        "body": "testing lang tol"
      },
      "output_variables": {
        "draft_id": "draft_id"
      },
      "description": "Create a draft email to jdenziieel@gmail.com with the subject 'Pakyu' and the body 'testing lang tol'"
    },
    {
      "agent": "gmail_agent",
      "tool": "send_draft_email",
      "inputs": {
        "draft_id": "{{ draft_id }}"
      },
      "output_variables": {},
      "description": "Send the created draft email"
    }
  ]
}