{
  "steps": [
    {
      "agent": "calendar_agent",
      "tool": "list_events",
      "inputs": {
        "time_min": "{{ today_date }}",
        "max_results": 10
      },
      "output_variables": {
        "upcoming_events": "events"
      },
      "description": "List the upcoming events from the user's calendar"
    }
  ]
}