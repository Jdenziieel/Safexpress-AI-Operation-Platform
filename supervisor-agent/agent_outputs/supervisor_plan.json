{
  "steps": [
    {
      "agent": "drive_agent",
      "tool": "search_files",
      "inputs": {
        "search_term": "project_brief"
      },
      "output_variables": {
        "template_file_id": "results[0].id"
      },
      "description": "Search for the file 'project_brief' in Google Drive"
    },
    {
      "agent": "docs_agent",
      "tool": "create_from_uploaded_template",
      "inputs": {
        "template_file_id": "{{ template_file_id }}",
        "new_title": "New_Document_Brief"
      },
      "output_variables": {},
      "description": "Create a new document titled 'New_Document_Brief' from the found file"
    }
  ]
}