[2026-04-26 04:48:40.271] [PRINT]       "body": "Dear Customer Service Team,\n\nI am writing to express my dissatisfaction with the delivery process for my\nrecent order, 88292.\n\nThe package failed to arrive within the timeframe promised at checkout, and\nI received no proactive communication regarding this delay. Reliable\ndelivery is a critical part of the shopping experience, and unfortunately,\nthis order fell well short of expectations.\n\nI would appreciate it if you could investigate why this delay occurred and\nprovide me with an update on when I can expect consistent service in the\nfuture.\n\nBest regards,\n\nCharles Michael Carla",
[2026-04-26 04:48:40.271] [PRINT]       "has_attachments": false,
[2026-04-26 04:48:40.271] [PRINT]       "attachments": [],
[2026-04-26 04:48:40.271] [PRINT]       "body_full": "Dear Customer Service Team,\r\n\r\nI am writing to express my dissatisfaction with the delivery process for my\r\nrecent order, 88292.\r\n\r\nThe package failed to arrive within the timeframe promised at checkout, and\r\nI received no proactive communication regarding this delay. Reliable\r\ndelivery is a critical part of the shopping experience, and unfortunately,\r\nthis order fell well short of expectations.\r\n\r\nI would appreciate it if you could investigate why this delay occurred and\r\nprovide me with an update on when I can expect consistent service in the\r\nfuture.\r\n\r\nBest regards,\r\n\r\nCharles Michael Carla\r\n",
[2026-04-26 04:48:40.271] [PRINT]       "body_links": []
[2026-04-26 04:48:40.271] [PRINT]     },
[2026-04-26 04:48:40.271] [PRINT]     {
[2026-04-26 04:48:40.271] [PRINT]       "message_id": "19dc60f52e5a0dd3",
