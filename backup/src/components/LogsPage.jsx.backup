import { useState, useEffect, useRef } from "react";
import {
  Search,
  RefreshCw,
  Filter,
  Clock,
  Zap,
  DollarSign,
  AlertCircle,
  CheckCircle,
  XCircle,
  Info,
  ChevronDown,
  ChevronUp,
  Activity,
  Database,
  Bot,
  Cpu,
  TrendingUp,
  BarChart3,
  Download,
  Calendar,
  X,
  Loader2,
} from "lucide-react";
import "../css/LogsPage.css";

const API_BASE_URL = "http://localhost:8010";

// Log level badge colors
const LOG_LEVEL_STYLES = {
  DEBUG: { bg: "#e2e8f0", color: "#475569", icon: Info },
  INFO: { bg: "#dbeafe", color: "#1d4ed8", icon: Info },
  PROGRESS: { bg: "#d1fae5", color: "#059669", icon: Activity },
  WARNING: { bg: "#fef3c7", color: "#d97706", icon: AlertCircle },
  ERROR: { bg: "#fee2e2", color: "#dc2626", icon: XCircle },
  CRITICAL: { bg: "#fecaca", color: "#991b1b", icon: AlertCircle },
};

// Agent Performance Card Component
function AgentPerformanceCard({ agent, metrics }) {
  const getScoreColor = (score) => {
    if (score >= 85) return "#10b981";
    if (score >= 70) return "#3b82f6";
    if (score >= 50) return "#f59e0b";
    return "#ef4444";
  };

  const getTier = (score) => {
    if (score >= 85) return { label: "Excellent", color: "#10b981" };
    if (score >= 70) return { label: "Good", color: "#3b82f6" };
    if (score >= 50) return { label: "Fair", color: "#f59e0b" };
    return { label: "Poor", color: "#ef4444" };
  };

  const overallScore = metrics.overall_score || 0;
  const tier = getTier(overallScore);

  return (
    <div className="agent-performance-card">
      <div className="agent-card-header">
        <div className="agent-icon">
          <Bot size={20} />
        </div>
        <div className="agent-info">
          <h4>{agent}</h4>
          <span className="agent-tier" style={{ backgroundColor: tier.color }}>
            {tier.label}
          </span>
        </div>
        <div
          className="agent-score"
          style={{ backgroundColor: getScoreColor(overallScore) }}
        >
          {overallScore.toFixed(0)}
        </div>
      </div>

      <div className="agent-metrics">
        <div className="metric-row">
          <span className="metric-label">Accuracy</span>
          <div className="metric-bar-container">
            <div
              className="metric-bar"
              style={{
                width: `${metrics.accuracy || 0}%`,
                backgroundColor: "#8b5cf6",
              }}
            />
          </div>
          <span className="metric-value">{(metrics.accuracy || 0).toFixed(0)}%</span>
        </div>
        <div className="metric-row">
          <span className="metric-label">Speed</span>
          <div className="metric-bar-container">
            <div
              className="metric-bar"
              style={{
                width: `${metrics.speed || 0}%`,
                backgroundColor: "#06b6d4",
              }}
            />
          </div>
          <span className="metric-value">{(metrics.speed || 0).toFixed(0)}</span>
        </div>
        <div className="metric-row">
          <span className="metric-label">Reliability</span>
          <div className="metric-bar-container">
            <div
              className="metric-bar"
              style={{
                width: `${metrics.reliability || 0}%`,
                backgroundColor: "#10b981",
              }}
            />
          </div>
          <span className="metric-value">{(metrics.reliability || 0).toFixed(0)}%</span>
        </div>
        <div className="metric-row">
          <span className="metric-label">Efficiency</span>
          <div className="metric-bar-container">
            <div
              className="metric-bar"
              style={{
                width: `${metrics.efficiency || 70}%`,
                backgroundColor: "#f59e0b",
              }}
            />
          </div>
          <span className="metric-value">{(metrics.efficiency || 70).toFixed(0)}</span>
        </div>
      </div>

      <div className="agent-stats">
        <div className="stat-item">
          <span className="stat-value">{metrics.total_calls || 0}</span>
          <span className="stat-label">Calls</span>
        </div>
        <div className="stat-item">
          <span className="stat-value">{(metrics.avg_latency_ms / 1000 || 0).toFixed(1)}s</span>
          <span className="stat-label">Avg Time</span>
        </div>
        <div className="stat-item">
          <span className="stat-value">{(metrics.success_rate || 0).toFixed(0)}%</span>
          <span className="stat-label">Success</span>
        </div>
      </div>
    </div>
  );
}

// Stats Card Component
function StatsCard({ title, value, subtitle, icon: Icon, trend, color }) {
  return (
    <div className="stats-card">
      <div className="stats-card-icon" style={{ backgroundColor: `${color}20`, color }}>
        <Icon size={24} />
      </div>
      <div className="stats-card-content">
        <p className="stats-card-title">{title}</p>
        <h3 className="stats-card-value">{value}</h3>
        {subtitle && <p className="stats-card-subtitle">{subtitle}</p>}
      </div>
      {trend && (
        <div className={`stats-card-trend ${trend > 0 ? "positive" : "negative"}`}>
          <TrendingUp size={14} />
          <span>{Math.abs(trend)}%</span>
        </div>
      )}
    </div>
  );
}

// Log Entry Row Component
function LogEntryRow({ log, onExpand, isExpanded }) {
  const levelStyle = LOG_LEVEL_STYLES[log.level] || LOG_LEVEL_STYLES.INFO;
  const LevelIcon = levelStyle.icon;

  const formatTimestamp = (timestamp) => {
    const date = new Date(timestamp);
    return date.toLocaleTimeString("en-US", {
      hour: "2-digit",
      minute: "2-digit",
      second: "2-digit",
    });
  };

  return (
    <>
      <tr className={`log-row ${isExpanded ? "expanded" : ""}`} onClick={onExpand}>
        <td className="log-time">{formatTimestamp(log.timestamp)}</td>
        <td>
          <span
            className="log-level-badge"
            style={{ backgroundColor: levelStyle.bg, color: levelStyle.color }}
          >
            <LevelIcon size={12} />
            {log.level}
          </span>
        </td>
        <td className="log-component">{log.component || log.logger || "-"}</td>
        <td className="log-message">{log.message}</td>
        <td className="log-expand">
          {isExpanded ? <ChevronUp size={16} /> : <ChevronDown size={16} />}
        </td>
      </tr>
      {isExpanded && (
        <tr className="log-details-row">
          <td colSpan={5}>
            <div className="log-details">
              <div className="log-detail-grid">
                {log.request_id && (
                  <div className="log-detail-item">
                    <span className="detail-label">Request ID</span>
                    <span className="detail-value code">{log.request_id}</span>
                  </div>
                )}
                {log.thread_id && (
                  <div className="log-detail-item">
                    <span className="detail-label">Thread ID</span>
                    <span className="detail-value code">{log.thread_id}</span>
                  </div>
                )}
                {log.operation && (
                  <div className="log-detail-item">
                    <span className="detail-label">Operation</span>
                    <span className="detail-value">{log.operation}</span>
                  </div>
                )}
                {log.conversation_id && (
                  <div className="log-detail-item">
                    <span className="detail-label">Conversation</span>
                    <span className="detail-value code">{log.conversation_id}</span>
                  </div>
                )}
              </div>
              {log.data && (
                <div className="log-data">
                  <span className="detail-label">Data</span>
                  <pre>{JSON.stringify(log.data, null, 2)}</pre>
                </div>
              )}
            </div>
          </td>
        </tr>
      )}
    </>
  );
}

// Main LogsPage Component
function LogsPage() {
  const [activeTab, setActiveTab] = useState("overview");
  const [logs, setLogs] = useState([]);
  const [stats, setStats] = useState(null);
  const [agentMetrics, setAgentMetrics] = useState({});
  const [isLoading, setIsLoading] = useState(true);
  const [isRefreshing, setIsRefreshing] = useState(false);
  const [expandedLogId, setExpandedLogId] = useState(null);
  
  // Filters
  const [searchQuery, setSearchQuery] = useState("");
  const [levelFilter, setLevelFilter] = useState("");
  const [componentFilter, setComponentFilter] = useState("");
  const [showFilters, setShowFilters] = useState(false);
  
  // Pagination
  const [currentPage, setCurrentPage] = useState(1);
  const [totalLogs, setTotalLogs] = useState(0);
  const logsPerPage = 50;

  // Auto-refresh
  const [autoRefresh, setAutoRefresh] = useState(false);
  const autoRefreshRef = useRef(null);

  // Fetch logs from API
  const fetchLogs = async (page = 1) => {
    try {
      const offset = (page - 1) * logsPerPage;
      let url = `${API_BASE_URL}/logs?limit=${logsPerPage}&offset=${offset}`;
      
      if (levelFilter) url += `&level=${levelFilter}`;
      if (componentFilter) url += `&component=${componentFilter}`;
      
      const response = await fetch(url);
      if (!response.ok) throw new Error("Failed to fetch logs");
      
      const data = await response.json();
      setLogs(data.logs || []);
      setTotalLogs(data.total || 0);
    } catch (error) {
      console.error("Error fetching logs:", error);
    }
  };

  // Search logs
  const searchLogs = async () => {
    if (!searchQuery.trim()) {
      fetchLogs(1);
      return;
    }
    
    try {
      setIsLoading(true);
      const response = await fetch(
        `${API_BASE_URL}/logs/search?q=${encodeURIComponent(searchQuery)}&limit=${logsPerPage}`
      );
      if (!response.ok) throw new Error("Failed to search logs");
      
      const data = await response.json();
      setLogs(data.logs || []);
      setTotalLogs(data.total || 0);
      setCurrentPage(1);
    } catch (error) {
      console.error("Error searching logs:", error);
    } finally {
      setIsLoading(false);
    }
  };

  // Fetch stats
  const fetchStats = async () => {
    try {
      const response = await fetch(`${API_BASE_URL}/logs/stats`);
      if (!response.ok) throw new Error("Failed to fetch stats");
      
      const data = await response.json();
      setStats(data);
    } catch (error) {
      console.error("Error fetching stats:", error);
    }
  };

  // Fetch agent performance metrics from the backend
  const fetchAgentMetrics = async () => {
    try {
      const response = await fetch(`${API_BASE_URL}/agents/metrics`);
      if (!response.ok) {
        // If endpoint not available, use calculated metrics
        console.warn("Agent metrics endpoint not available, using fallback");
        return;
      }
      
      const data = await response.json();
      if (data.metrics) {
        setAgentMetrics(data.metrics);
      }
    } catch (error) {
      console.error("Error fetching agent metrics:", error);
      // Fallback: calculate from stats if available
      if (stats?.request_analytics) {
        calculateAgentMetrics(stats);
      }
    }
  };

  // Calculate agent performance metrics (fallback when API not available)
  const calculateAgentMetrics = (statsData) => {
    // This is a simplified calculation - in production, you'd have dedicated endpoints
    const agents = ["gmail", "gdocs", "calendar", "sheets", "gdrive"];
    const metrics = {};
    
    agents.forEach((agent) => {
      // Generate sample metrics (replace with real data from API)
      const successRate = 85 + Math.random() * 15;
      const avgLatency = 1500 + Math.random() * 3500;
      const latencyScore = avgLatency < 3000 ? 100 : avgLatency < 10000 ? 75 : 50;
      
      metrics[agent] = {
        accuracy: successRate, // Using success rate as proxy for accuracy
        speed: latencyScore,
        reliability: successRate,
        efficiency: 70 + Math.random() * 20,
        total_calls: Math.floor(50 + Math.random() * 200),
        avg_latency_ms: avgLatency,
        success_rate: successRate,
        overall_score:
          successRate * 0.35 +
          latencyScore * 0.25 +
          successRate * 0.15 +
          75 * 0.1 +
          (70 + Math.random() * 20) * 0.15,
      };
    });
    
    setAgentMetrics(metrics);
  };

  // Load all data
  const loadAllData = async () => {
    setIsLoading(true);
    try {
      await Promise.all([fetchLogs(currentPage), fetchStats(), fetchAgentMetrics()]);
    } finally {
      setIsLoading(false);
    }
  };

  // Refresh data
  const handleRefresh = async () => {
    setIsRefreshing(true);
    await Promise.all([loadAllData(), fetchAgentMetrics()]);
    setIsRefreshing(false);
  };

  // Initial load
  useEffect(() => {
    loadAllData();
  }, []);

  // Reload when filters change
  useEffect(() => {
    if (!isLoading) {
      fetchLogs(1);
      setCurrentPage(1);
    }
  }, [levelFilter, componentFilter]);

  // Auto-refresh
  useEffect(() => {
    if (autoRefresh) {
      autoRefreshRef.current = setInterval(() => {
        fetchLogs(currentPage);
        fetchStats();
      }, 10000); // Refresh every 10 seconds
    } else {
      if (autoRefreshRef.current) {
        clearInterval(autoRefreshRef.current);
      }
    }
    
    return () => {
      if (autoRefreshRef.current) {
        clearInterval(autoRefreshRef.current);
      }
    };
  }, [autoRefresh, currentPage]);

  // Pagination
  const totalPages = Math.ceil(totalLogs / logsPerPage);
  
  const handlePageChange = (newPage) => {
    setCurrentPage(newPage);
    fetchLogs(newPage);
  };

  // Format numbers
  const formatNumber = (num) => {
    if (num >= 1000000) return (num / 1000000).toFixed(1) + "M";
    if (num >= 1000) return (num / 1000).toFixed(1) + "K";
    return num?.toLocaleString() || "0";
  };

  const formatCost = (cost) => {
    if (!cost) return "$0.00";
    return "$" + cost.toFixed(4);
  };

  if (isLoading && !logs.length) {
    return (
      <div className="logs-page">
        <div className="logs-loading">
          <Loader2 size={48} className="spinner" />
          <p>Loading logs...</p>
        </div>
      </div>
    );
  }

  return (
    <div className="logs-page">
      {/* Header */}
      <div className="logs-header">
        <div className="logs-header-left">
          <h1>
            <Database size={28} />
            System Logs & Analytics
          </h1>
          <p>Monitor agent performance, track requests, and analyze system health</p>
        </div>
        <div className="logs-header-actions">
          <label className="auto-refresh-toggle">
            <input
              type="checkbox"
              checked={autoRefresh}
              onChange={(e) => setAutoRefresh(e.target.checked)}
            />
            <span>Auto-refresh</span>
          </label>
          <button
            className="refresh-btn"
            onClick={handleRefresh}
            disabled={isRefreshing}
          >
            <RefreshCw size={18} className={isRefreshing ? "spinner" : ""} />
            Refresh
          </button>
        </div>
      </div>

      {/* Tabs */}
      <div className="logs-tabs">
        <button
          className={`tab-btn ${activeTab === "overview" ? "active" : ""}`}
          onClick={() => setActiveTab("overview")}
        >
          <BarChart3 size={18} />
          Overview
        </button>
        <button
          className={`tab-btn ${activeTab === "agents" ? "active" : ""}`}
          onClick={() => setActiveTab("agents")}
        >
          <Bot size={18} />
          Agent Performance
        </button>
        <button
          className={`tab-btn ${activeTab === "logs" ? "active" : ""}`}
          onClick={() => setActiveTab("logs")}
        >
          <Activity size={18} />
          Live Logs
        </button>
      </div>

      {/* Overview Tab */}
      {activeTab === "overview" && (
        <div className="logs-content">
          {/* Stats Cards */}
          <div className="stats-grid">
            <StatsCard
              title="Total Requests"
              value={formatNumber(stats?.token_summary?.totals?.total_calls || 0)}
              subtitle="Last 24 hours"
              icon={Activity}
              color="#3b82f6"
            />
            <StatsCard
              title="Total Tokens"
              value={formatNumber(stats?.token_summary?.totals?.total_tokens || 0)}
              subtitle={`Input: ${formatNumber(stats?.token_summary?.totals?.total_input_tokens || 0)}`}
              icon={Zap}
              color="#8b5cf6"
            />
            <StatsCard
              title="Total Cost"
              value={formatCost(stats?.token_summary?.totals?.total_cost_usd)}
              subtitle="Estimated"
              icon={DollarSign}
              color="#10b981"
            />
            <StatsCard
              title="Success Rate"
              value={
                stats?.token_summary?.totals?.successful_calls && stats?.token_summary?.totals?.total_calls
                  ? ((stats.token_summary.totals.successful_calls / stats.token_summary.totals.total_calls) * 100).toFixed(1) + "%"
                  : "N/A"
              }
              subtitle="All agents"
              icon={CheckCircle}
              color="#06b6d4"
            />
          </div>

          {/* Usage by Model */}
          {stats?.token_summary?.by_model && stats.token_summary.by_model.length > 0 && (
            <div className="stats-section">
              <h3>
                <Cpu size={20} />
                Usage by Model
              </h3>
              <div className="model-stats-grid">
                {stats.token_summary.by_model.map((model, idx) => (
                  <div key={idx} className="model-stat-card">
                    <div className="model-name">{model.model || "Unknown"}</div>
                    <div className="model-stats">
                      <div className="model-stat">
                        <span className="stat-value">{formatNumber(model.calls)}</span>
                        <span className="stat-label">Calls</span>
                      </div>
                      <div className="model-stat">
                        <span className="stat-value">{formatNumber(model.tokens)}</span>
                        <span className="stat-label">Tokens</span>
                      </div>
                      <div className="model-stat">
                        <span className="stat-value">{formatCost(model.cost_usd)}</span>
                        <span className="stat-label">Cost</span>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}

          {/* Recent Requests */}
          {stats?.request_analytics && stats.request_analytics.length > 0 && (
            <div className="stats-section">
              <h3>
                <Clock size={20} />
                Recent Requests
              </h3>
              <div className="requests-table-container">
                <table className="requests-table">
                  <thead>
                    <tr>
                      <th>Request ID</th>
                      <th>Started</th>
                      <th>LLM Calls</th>
                      <th>Tokens</th>
                      <th>Cost</th>
                      <th>Models</th>
                    </tr>
                  </thead>
                  <tbody>
                    {stats.request_analytics.slice(0, 10).map((req, idx) => (
                      <tr key={idx}>
                        <td className="code">{req.request_id?.slice(0, 12)}...</td>
                        <td>{new Date(req.started_at).toLocaleTimeString()}</td>
                        <td>{req.llm_calls}</td>
                        <td>{formatNumber(req.total_tokens)}</td>
                        <td>{formatCost(req.total_cost_usd)}</td>
                        <td>{req.models_used}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          )}
        </div>
      )}

      {/* Agent Performance Tab */}
      {activeTab === "agents" && (
        <div className="logs-content">
          <div className="agents-grid">
            {Object.entries(agentMetrics).map(([agent, metrics]) => (
              <AgentPerformanceCard key={agent} agent={agent} metrics={metrics} />
            ))}
          </div>
          
          {Object.keys(agentMetrics).length === 0 && (
            <div className="no-data">
              <Bot size={48} />
              <p>No agent performance data available yet.</p>
              <p className="hint">Agent metrics will appear as requests are processed.</p>
            </div>
          )}
        </div>
      )}

      {/* Live Logs Tab */}
      {activeTab === "logs" && (
        <div className="logs-content">
          {/* Search and Filters */}
          <div className="logs-toolbar">
            <div className="search-container">
              <Search size={18} />
              <input
                type="text"
                placeholder="Search logs..."
                value={searchQuery}
                onChange={(e) => setSearchQuery(e.target.value)}
                onKeyDown={(e) => e.key === "Enter" && searchLogs()}
              />
              {searchQuery && (
                <button className="clear-search" onClick={() => {
                  setSearchQuery("");
                  fetchLogs(1);
                }}>
                  <X size={16} />
                </button>
              )}
            </div>
            
            <button
              className={`filter-toggle ${showFilters ? "active" : ""}`}
              onClick={() => setShowFilters(!showFilters)}
            >
              <Filter size={18} />
              Filters
              {(levelFilter || componentFilter) && <span className="filter-badge">!</span>}
            </button>
          </div>

          {/* Filter Panel */}
          {showFilters && (
            <div className="filters-panel">
              <div className="filter-group">
                <label>Log Level</label>
                <select
                  value={levelFilter}
                  onChange={(e) => setLevelFilter(e.target.value)}
                >
                  <option value="">All Levels</option>
                  <option value="DEBUG">Debug</option>
                  <option value="INFO">Info</option>
                  <option value="PROGRESS">Progress</option>
                  <option value="WARNING">Warning</option>
                  <option value="ERROR">Error</option>
                  <option value="CRITICAL">Critical</option>
                </select>
              </div>
              <div className="filter-group">
                <label>Component</label>
                <select
                  value={componentFilter}
                  onChange={(e) => setComponentFilter(e.target.value)}
                >
                  <option value="">All Components</option>
                  <option value="llm">LLM</option>
                  <option value="orchestrator">Orchestrator</option>
                  <option value="api">API</option>
                  <option value="supervisor">Supervisor</option>
                </select>
              </div>
              <button
                className="clear-filters"
                onClick={() => {
                  setLevelFilter("");
                  setComponentFilter("");
                }}
              >
                Clear Filters
              </button>
            </div>
          )}

          {/* Logs Table */}
          <div className="logs-table-container">
            <table className="logs-table">
              <thead>
                <tr>
                  <th style={{ width: "100px" }}>Time</th>
                  <th style={{ width: "100px" }}>Level</th>
                  <th style={{ width: "120px" }}>Component</th>
                  <th>Message</th>
                  <th style={{ width: "40px" }}></th>
                </tr>
              </thead>
              <tbody>
                {logs.map((log, idx) => (
                  <LogEntryRow
                    key={log.id || idx}
                    log={log}
                    isExpanded={expandedLogId === (log.id || idx)}
                    onExpand={() =>
                      setExpandedLogId(
                        expandedLogId === (log.id || idx) ? null : (log.id || idx)
                      )
                    }
                  />
                ))}
              </tbody>
            </table>

            {logs.length === 0 && (
              <div className="no-logs">
                <Activity size={48} />
                <p>No logs found</p>
                {(searchQuery || levelFilter || componentFilter) && (
                  <p className="hint">Try adjusting your search or filters</p>
                )}
              </div>
            )}
          </div>

          {/* Pagination */}
          {totalPages > 1 && (
            <div className="pagination">
              <button
                disabled={currentPage === 1}
                onClick={() => handlePageChange(currentPage - 1)}
              >
                Previous
              </button>
              <span className="page-info">
                Page {currentPage} of {totalPages} ({totalLogs} total logs)
              </span>
              <button
                disabled={currentPage === totalPages}
                onClick={() => handlePageChange(currentPage + 1)}
              >
                Next
              </button>
            </div>
          )}
        </div>
      )}
    </div>
  );
}

export default LogsPage;
