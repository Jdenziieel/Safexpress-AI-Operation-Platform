# ============================================================================
# ENVIRONMENT CONFIGURATION
# ============================================================================
# Copy this file to .env and fill in your actual values
# Never commit .env to version control!

# Environment: development, staging, production
ENVIRONMENT=development

# ============================================================================
# OPENAI CONFIGURATION
# ============================================================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1

# ============================================================================
# WEAVIATE CONFIGURATION
# ============================================================================
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=your-weaviate-api-key-here

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
# IMPORTANT: This MUST match your Django auth server's JWT_SECRET_KEY
JWT_SECRET_KEY=your-super-secret-jwt-key-here-min-32-chars

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
# Rate limiting (set to false to disable)
RATE_LIMIT_ENABLED=true

# CORS allowed origins (comma-separated)
# Development:
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173
# Production (example):
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================================================
# HTTPS/TLS CONFIGURATION (Production Only)
# ============================================================================
# Enable HTTPS (recommended to use reverse proxy instead)
USE_HTTPS=false

# SSL Certificate paths (only needed if USE_HTTPS=true)
# SSL_CERTFILE=/path/to/cert.pem
# SSL_KEYFILE=/path/to/key.pem

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
PORT=8009
DEBUG=true

# ============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# ============================================================================
# Before deploying to production:
# 
# 1. Set ENVIRONMENT=production
# 2. Set DEBUG=false
# 3. Use strong JWT_SECRET_KEY (32+ characters, random)
# 4. Update ALLOWED_ORIGINS to your actual domain
# 5. Enable RATE_LIMIT_ENABLED=true
# 6. Use HTTPS via reverse proxy (Nginx/Caddy)
# 7. Store secrets in Azure Key Vault or similar
# 8. Configure proper logging and monitoring
# 9. Set up database backups
# 10. Run security audit: pip install pip-audit && pip-audit
# ============================================================================
