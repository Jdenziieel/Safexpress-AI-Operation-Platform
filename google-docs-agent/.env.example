# ============================================
# GOOGLE DOCS AGENT - Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values

# ============================================
# OpenAI Configuration
# ============================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================
# Google OAuth 2.0 Credentials
# ============================================
# Get these from: https://console.cloud.google.com/apis/credentials
# 1. Create OAuth 2.0 Client ID
# 2. Download credentials or copy Client ID and Secret

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ============================================
# Google OAuth Tokens (For Testing Only)
# ============================================
# In production, these come from your Django OAuth flow
# For testing, you can get them by running the OAuth flow once
# See README.md "Get OAuth Tokens" section

# Optional: For testing with real Google account
GOOGLE_ACCESS_TOKEN=your-access-token-here
GOOGLE_REFRESH_TOKEN=your-refresh-token-here

# ============================================
# Optional: Agent Configuration
# ============================================
# Uncomment to customize agent behavior

# GPT model to use (default: gpt-4)
# MODEL_NAME=gpt-4

# Temperature (0 = focused, 1 = creative)
# TEMPERATURE=0

# Enable verbose logging
# VERBOSE=true
