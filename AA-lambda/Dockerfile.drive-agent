# Lambda Docker image for agent-drive.
#
# Heavy because:
# - pdfplumber / pymupdf (parse downloaded PDFs)
# - pandas / openpyxl (Excel handling)
# - google-api-python-client (Drive API)
#
# Usage:
#   docker build -t agent-drive:latest -f Dockerfile.drive-agent .

# syntax=docker/dockerfile:1.6
FROM public.ecr.aws/lambda/python:3.12

# AL2023 ships dnf. Build-deps kept for wheels that don't ship manylinux_2_28.
RUN dnf install -y gcc gcc-c++ make && dnf clean all

# BuildKit cache mount: persists wheels across builds. See Dockerfile.lambda.
COPY functions/agent-drive/requirements.txt /var/task/requirements-fn.txt
RUN --mount=type=cache,target=/root/.cache/pip,sharing=locked \
    pip install --no-cache-dir -r /var/task/requirements-fn.txt

COPY functions/agent-drive/ /var/task/

CMD ["lambda_function.lambda_handler"]
