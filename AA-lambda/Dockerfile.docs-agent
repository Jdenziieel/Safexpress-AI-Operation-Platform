# Lambda Docker image for agent-docs.
#
# Heavy because:
# - langchain / langgraph / langchain-openai (the dead-but-imported task path)
# - google-api-python-client + httplib2 (Google Docs API)
#
# Usage:
#   docker build -t agent-docs:latest -f Dockerfile.docs-agent .

# syntax=docker/dockerfile:1.6
FROM public.ecr.aws/lambda/python:3.12

# --- Per-function deps ---
# BuildKit cache mount: persists wheels across builds. See Dockerfile.lambda.
COPY functions/agent-docs/requirements.txt /var/task/requirements-fn.txt
RUN --mount=type=cache,target=/root/.cache/pip,sharing=locked \
    pip install --no-cache-dir -r /var/task/requirements-fn.txt

# --- Function code ---
COPY functions/agent-docs/ /var/task/

CMD ["lambda_function.lambda_handler"]
