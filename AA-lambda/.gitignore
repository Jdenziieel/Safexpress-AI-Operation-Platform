# Lambda packaging artifacts — regenerated by build-lambda.ps1 /
# build-lambda-docker.ps1. Each contains the bundled vendor tree
# (boto3, certifi, openai, etc.) which adds 100s of MB of churn for
# zero source-code value. The PowerShell builders rebuild these
# on demand from each function's requirements.txt, so checking them
# in would only create stale-bundle bugs.
build/
dist/
*.zip
*.tar.gz

# Python bytecode + venv churn
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
venv/
.venv/
env/
.env

# Local-only state
*.db
*.sqlite3
threads.db
logs.db

# IDE / OS noise
.idea/
.vscode/
.DS_Store
Thumbs.db

# Local secret scratch (these MUST never land in git — Lambdas read
# secrets from AWS Secrets Manager / Lambda env vars at runtime,
# not from a .env file in the repo).
*.env
.env.*
!.env.example
credentials.json
client_secret*.json
service-account*.json
