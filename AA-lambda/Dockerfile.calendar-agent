# Lambda Docker image for agent-calendar.
#
# Self-contained: does NOT pull in the supervisor brain (`shared/`) and does
# NOT install the top-level `requirements.txt` / `requirements-heavy.txt`.
# Only this agent's per-function requirements.txt is installed:
#   - google-auth + google-api-python-client (Calendar REST)
#   - pytz / python-dateutil (event time math)
#   - fastapi + uvicorn (api.py legacy imports)
#
# Previously fell through to Dockerfile.lambda, which dragged in the entire
# supervisor brain + LangGraph stack (~700 MB of unused wheels). This file
# fixes that.
#
# Usage:
#   docker build -t agent-calendar:latest -f Dockerfile.calendar-agent .

# syntax=docker/dockerfile:1.6
FROM public.ecr.aws/lambda/python:3.12

# --- Per-function deps ---
COPY functions/agent-calendar/requirements.txt /var/task/requirements-fn.txt
RUN --mount=type=cache,target=/root/.cache/pip,sharing=locked \
    pip install --no-cache-dir -r /var/task/requirements-fn.txt

# --- Function code ---
COPY functions/agent-calendar/ /var/task/

CMD ["lambda_function.lambda_handler"]
