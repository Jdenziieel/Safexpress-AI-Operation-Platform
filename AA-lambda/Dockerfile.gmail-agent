# Lambda Docker image for agent-gmail.
#
# Self-contained: does NOT pull in the supervisor brain (`shared/`) and does
# NOT install the top-level `requirements.txt` / `requirements-heavy.txt`.
# Only this agent's per-function requirements.txt is installed, which is
# already trimmed to:
#   - google-auth + google-api-python-client (Gmail REST)
#   - langchain-openai (body-rewrite signature)
#   - beautifulsoup4 (HTML email cleanup)
#   - fastapi + uvicorn (only because api.py imports them at module top
#     level for parity with the local agent — Lambda never serves over
#     uvicorn)
#
# Previously fell through to Dockerfile.lambda, which dragged in the entire
# supervisor brain + LangGraph stack (~700 MB of unused wheels). This file
# fixes that.
#
# Usage:
#   docker build -t agent-gmail:latest -f Dockerfile.gmail-agent .

# syntax=docker/dockerfile:1.6
FROM public.ecr.aws/lambda/python:3.12

# --- Per-function deps ---
# BuildKit cache mount: persists wheels across builds. See Dockerfile.lambda.
COPY functions/agent-gmail/requirements.txt /var/task/requirements-fn.txt
RUN --mount=type=cache,target=/root/.cache/pip,sharing=locked \
    pip install --no-cache-dir -r /var/task/requirements-fn.txt

# --- Function code ---
COPY functions/agent-gmail/ /var/task/

CMD ["lambda_function.lambda_handler"]
