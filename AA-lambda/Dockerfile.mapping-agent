# Lambda Docker image for agent-mapping.
#
# Heavy because:
# - pandas / numpy (data transforms)
# - pdfplumber / pymupdf (PDF parsing for delivery orders)
# - openai (smart column mapping LLM tier)
#
# Usage:
#   docker build -t agent-mapping:latest -f Dockerfile.mapping-agent .

# syntax=docker/dockerfile:1.6
FROM public.ecr.aws/lambda/python:3.12

# AL2023 ships dnf instead of yum. Build-deps for any wheel without
# manylinux_2_28 prebuilt wheel (rare; most numpy/pandas/pdf libs ship them).
RUN dnf install -y gcc gcc-c++ make && dnf clean all

# --- Per-function deps ---
# BuildKit cache mount: persists wheels across builds. See Dockerfile.lambda.
COPY functions/agent-mapping/requirements.txt /var/task/requirements-fn.txt
RUN --mount=type=cache,target=/root/.cache/pip,sharing=locked \
    pip install --no-cache-dir -r /var/task/requirements-fn.txt

# --- Function code ---
COPY functions/agent-mapping/ /var/task/

CMD ["lambda_function.lambda_handler"]
